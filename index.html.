<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Doanlifestyle TTS Ultra</title>

<style>
body{
  margin:0;
  font-family:Arial;
  background:linear-gradient(135deg,#020617,#0f172a);
  color:white;
}
.container{
  max-width:1100px;
  margin:auto;
  padding:20px;
}
h1{margin-bottom:10px}
.layout{
  display:grid;
  grid-template-columns:1.5fr 1fr;
  gap:20px;
}
.card{
  background:#0f172a;
  padding:20px;
  border-radius:16px;
}
textarea{
  width:100%;
  height:200px;
  border-radius:10px;
  padding:10px;
}
input,select{
  width:100%;
  padding:10px;
  border-radius:10px;
  margin-top:10px;
}
button{
  margin-top:10px;
  padding:12px;
  border:none;
  border-radius:10px;
  cursor:pointer;
}
.green{background:#22c55e}
.blue{background:#3b82f6}
.orange{background:#f59e0b}
.red{background:#ef4444}

.voice{
  padding:10px;
  margin:5px 0;
  border-radius:10px;
  background:#1e293b;
  cursor:pointer;
}
.voice.active{
  border:2px solid #3b82f6;
}
</style>
</head>

<body>

<div class="container">

<h1>🔥 Doanlifestyle TTS Ultra</h1>

<div class="layout">

<!-- LEFT -->
<div class="card">

<h3>Nội dung</h3>

<textarea id="text">
Xin chào bạn...
Hôm nay mình chia sẻ với bạn...
</textarea>

<button class="green" onclick="generate()">Tạo audio</button>
<button class="blue" onclick="play()">Phát audio</button>
<button class="orange" onclick="download()">Tải audio</button>
<button class="red" onclick="resetAll()">Đặt lại</button>

</div>

<!-- RIGHT -->
<div class="card">

<h3>Cài đặt</h3>

<input id="apiKey" placeholder="OpenAI API key">

<select id="model">
<option value="gpt-4o-mini-tts">gpt-4o-mini-tts</option>
</select>

<label>Tốc độ</label>
<input type="range" id="speed" min="0.5" max="2" step="0.1" value="1">

<h4>Chọn voice</h4>

<div id="voices"></div>

</div>

</div>
</div>

<script>
let selectedVoice = "alloy";
let audioBlob = null;

const voiceList = ["alloy","ash","ballad","coral","echo","fable","nova","onyx"];

function renderVoices(){
  const box = document.getElementById("voices");
  box.innerHTML = "";
  voiceList.forEach(v=>{
    const div = document.createElement("div");
    div.className = "voice" + (v===selectedVoice ? " active":"");
    div.innerText = v;
    div.onclick = ()=>{
      selectedVoice = v;
      renderVoices();
    };
    box.appendChild(div);
  });
}

async function generate(){
  const key = document.getElementById("apiKey").value;
  const text = document.getElementById("text").value;
  const speed = document.getElementById("speed").value;

  if(!key){
    alert("Nhập API key");
    return;
  }

  const res = await fetch("https://api.openai.com/v1/audio/speech",{
    method:"POST",
    headers:{
      "Authorization":"Bearer "+key,
      "Content-Type":"application/json"
    },
    body:JSON.stringify({
      model:"gpt-4o-mini-tts",
      voice:selectedVoice,
      input:text,
      speed:parseFloat(speed)
    })
  });

  audioBlob = await res.blob();
  alert("Đã tạo audio!");
}

function play(){
  if(!audioBlob){alert("Chưa tạo audio");return;}
  const url = URL.createObjectURL(audioBlob);
  new Audio(url).play();
}

function download(){
  if(!audioBlob){alert("Chưa tạo audio");return;}
  const url = URL.createObjectURL(audioBlob);
  const a = document.createElement("a");
  a.href = url;
  a.download = "audio.mp3";
  a.click();
}

function resetAll(){
  document.getElementById("text").value = "";
}

renderVoices();
</script>

</body>
</html>
