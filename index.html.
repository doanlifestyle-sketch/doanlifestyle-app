<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title>Doanlifestyle TTS Ultra</title>
<style>
:root{
  --bg1:#050816;
  --bg2:#0c1630;
  --card:rgba(12,19,37,.82);
  --line:rgba(148,163,184,.16);
  --text:#f8fafc;
  --muted:#cbd5e1;
  --blue:#38bdf8;
  --violet:#8b5cf6;
  --green:#22c55e;
  --amber:#f59e0b;
  --red:#ef4444;
  --shadow:0 24px 60px rgba(0,0,0,.32);
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{
  margin:0;
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
  color:var(--text);
  background:
    radial-gradient(circle at top left, rgba(56,189,248,.18), transparent 24%),
    radial-gradient(circle at top right, rgba(139,92,246,.14), transparent 28%),
    linear-gradient(180deg,var(--bg1),var(--bg2) 55%, #111827);
  min-height:100vh;
  padding:16px;
}
.wrap{max-width:1180px;margin:0 auto}
.hero{padding:4px 2px 16px}
.badge{
  display:inline-flex;align-items:center;gap:8px;
  border-radius:999px;padding:8px 12px;
  background:rgba(56,189,248,.10);
  border:1px solid rgba(56,189,248,.22);
  color:#e0f2fe;font-weight:800;font-size:13px
}
h1{font-size:56px;line-height:1.02;margin:12px 0 10px}
.sub{max-width:980px;color:var(--muted);font-size:15px;line-height:1.65;margin:0}
.layout{display:grid;grid-template-columns:1.1fr .9fr;gap:16px}
.card{
  background:var(--card);
  border:1px solid var(--line);
  border-radius:28px;
  box-shadow:var(--shadow);
  backdrop-filter:blur(10px);
}
.left,.right{padding:20px}
.title{font-size:16px;font-weight:900;margin:0 0 8px}
.desc{margin:0 0 12px;color:var(--muted);line-height:1.6;font-size:14px}
label{display:block;font-weight:800;margin:0 0 8px}
input,textarea,select{
  width:100%;border-radius:16px;border:1px solid var(--line);
  background:#020817;color:var(--text);padding:14px;
  font-size:16px;outline:none
}
input::placeholder,textarea::placeholder{color:#94a3b8}
textarea{min-height:300px;resize:vertical;line-height:1.7}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.counter{text-align:right;color:#93c5fd;font-weight:800;font-size:13px;margin-top:8px}
button{
  border:none;border-radius:16px;padding:14px 12px;color:white;
  font-size:15px;font-weight:900;cursor:pointer
}
.green{background:linear-gradient(180deg,#4ade80,#16a34a)}
.blue{background:linear-gradient(180deg,#60a5fa,#0284c7)}
.amber{background:linear-gradient(180deg,#fbbf24,#d97706)}
.red{background:linear-gradient(180deg,#f87171,#dc2626)}
.ghost{background:#1e293b}
.rowBtns,.mainBtns{display:grid;gap:10px}
.rowBtns{grid-template-columns:repeat(4,1fr);margin-top:12px}
.mainBtns{grid-template-columns:repeat(4,1fr);margin-top:14px}
.pills{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
.pill{
  padding:10px 14px;border-radius:999px;border:1px solid var(--line);
  background:#0b1220;color:#e2e8f0;font-weight:800;font-size:14px;cursor:pointer
}
.pill.active{
  border-color:rgba(56,189,248,.5);
  background:rgba(56,189,248,.12);
  color:#fff
}
audio{width:100%;margin-top:12px;border-radius:16px;background:#020817}
.status,.notes{
  margin-top:12px;padding:14px 15px;border-radius:18px;
  border:1px solid var(--line);background:#081120;color:var(--muted);
  line-height:1.6;white-space:pre-wrap;font-size:14px
}
.right .field{margin-bottom:14px}
.check{
  display:flex;align-items:center;gap:10px;
  font-weight:800;margin:12px 0 6px;color:#dbeafe
}
.check input{width:auto;transform:scale(1.2)}
.speedRow{display:flex;align-items:center;gap:12px}
.speedValue{min-width:54px;text-align:right;color:#dbeafe;font-weight:900}
.voiceGrid{
  display:grid;grid-template-columns:1fr 1fr;gap:10px;
  max-height:560px;overflow:auto;padding-right:4px
}
.voiceCard{
  border:1px solid var(--line);border-radius:18px;background:#081120;padding:12px;
  cursor:pointer
}
.voiceCard.active{outline:2px solid rgba(56,189,248,.55)}
.voiceName{font-weight:900;font-size:18px}
.voiceMeta{font-size:13px;color:var(--muted);margin-top:6px}
.small{font-size:13px;color:var(--muted)}
.quick{
  margin-top:16px;border-top:1px solid var(--line);padding-top:16px
}
.quick ul{margin:8px 0 0 18px;padding:0;color:var(--muted);line-height:1.7}
.inlineBtns{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}
.footerNote{margin-top:14px;color:#94a3b8;font-size:13px;line-height:1.6}
@media (max-width:980px){
  .layout{grid-template-columns:1fr}
  h1{font-size:40px}
}
@media (max-width:760px){
  .rowBtns,.mainBtns,.grid2,.voiceGrid{grid-template-columns:1fr}
  textarea{min-height:240px}
}
</style>
</head>
<body>
<div class="wrap">
  <div class="hero">
    <div class="badge">🔥 TTS Ultra • đầy đủ voice + preset + tải audio</div>
    <h1>Doanlifestyle TTS Ultra</h1>
    <p class="sub">Bản này gom tất cả vào một nơi: đầy đủ voice đang có trong app, preset theo mục đích dùng, giao diện đẹp hơn, lưu cài đặt trên máy, phát thử và tải audio về iPhone.</p>
  </div>

  <div class="layout">
    <section class="card left">
      <h2 class="title">Nội dung</h2>
      <p class="desc">Dán truyện ngắn, lời dẫn YouTube, Kinh Thánh, lời cầu nguyện hoặc bất kỳ nội dung nào bạn muốn chuyển thành giọng đọc.</p>

      <label for="text">Văn bản</label>
      <textarea id="text">Xin chào bạn...
Hôm nay...
mình đã gom cho bạn bản đầy đủ hơn...

Bạn chỉ cần dán nội dung vào đây...
chọn giọng đọc mình thích...
rồi bấm tạo audio...

Sau đó...
bạn có thể tải file về iPhone.</textarea>
      <div class="counter" id="charCount">0 ký tự</div>

      <div class="rowBtns">
        <button class="ghost" id="sampleStoryBtn">Mẫu kể chuyện</button>
        <button class="ghost" id="sampleHealingBtn">Mẫu chữa lành</button>
        <button class="ghost" id="sampleYoutubeBtn">Mẫu YouTube</button>
        <button class="ghost" id="clearBtn">Xóa nội dung</button>
      </div>

      <div class="title" style="margin-top:18px">Preset nhanh</div>
      <div class="pills" id="presetWrap"></div>

      <div class="mainBtns">
        <button class="green" id="generateBtn">Tạo audio</button>
        <button class="blue" id="previewBtn">Phát audio</button>
        <button class="amber" id="downloadBtn">Tải audio</button>
        <button class="red" id="resetBtn">Đặt lại</button>
      </div>

      <audio id="audioPlayer" controls preload="none"></audio>
      <div class="status" id="status">Sẵn sàng.</div>
      <div class="notes">Bản này dùng endpoint tạo speech của OpenAI, nên bạn vẫn cần API key để tạo file audio.</div>
    </section>

    <aside class="card right">
      <h2 class="title">Cài đặt</h2>
      <p class="desc">Chọn model, voice, tốc độ và định dạng file theo ý bạn.</p>

      <div class="field">
        <label for="apiKey">OpenAI API key</label>
        <input id="apiKey" type="password" placeholder="Dán API key của bạn vào đây">
      </div>

      <label class="check">
        <input type="checkbox" id="rememberKey" checked>
        Nhớ API key trên máy này
      </label>

      <div class="grid2">
        <div class="field">
          <label for="fileName">Tên file</label>
          <input id="fileName" value="doanlifestyle_tts_ultra">
        </div>
        <div class="field">
          <label for="format">Định dạng</label>
          <select id="format">
            <option value="mp3" selected>mp3</option>
            <option value="wav">wav</option>
            <option value="opus">opus</option>
          </select>
        </div>
      </div>

      <div class="grid2">
        <div class="field">
          <label for="model">Model</label>
          <select id="model">
            <option value="gpt-4o-mini-tts" selected>gpt-4o-mini-tts</option>
            <option value="tts-1">tts-1</option>
            <option value="tts-1-hd">tts-1-hd</option>
          </select>
        </div>
        <div class="field">
          <label for="speed">Tốc độ</label>
          <div class="speedRow">
            <input id="speed" type="range" min="0.25" max="4" step="0.05" value="1.50">
            <div class="speedValue" id="speedValue">1.50</div>
          </div>
        </div>
      </div>

      <div class="field">
        <label for="instructions">Hướng dẫn giọng đọc</label>
        <input id="instructions" value="dịu dàng, nữ tính, mượt mà, cảm xúc nhẹ, rõ chữ">
      </div>

      <div class="title" style="margin-top:8px">Chọn voice</div>
      <div class="voiceGrid" id="voiceGrid"></div>

      <div class="quick">
        <div class="title">Gợi ý chọn nhanh</div>
        <ul>
          <li>Kể chuyện cảm xúc: <b>nova, ballad, fable</b></li>
          <li>Nữ dịu nhẹ: <b>shimmer, marin, coral</b></li>
          <li>Nam trầm: <b>onyx, cedar, sage</b></li>
          <li>Lời dẫn hiện đại: <b>coral, alloy, verse</b></li>
        </ul>
      </div>

      <div class="footerNote">
        Mẹo dùng trên iPhone:
        <br>• Mở file HTML này bằng Safari.
        <br>• Sau khi tạo xong, bấm <b>Tải audio</b>.
        <br>• Khi hiện hộp lưu, chọn <b>Tệp</b> để giữ file trên iPhone.
      </div>
    </aside>
  </div>
</div>

<script>
const voices = [
  { id:"alloy", label:"alloy", desc:"Cân bằng, dễ dùng" },
  { id:"ash", label:"ash", desc:"Rõ chữ, thuyết minh" },
  { id:"ballad", label:"ballad", desc:"Mềm, cảm xúc" },
  { id:"coral", label:"coral", desc:"Trẻ, hiện đại" },
  { id:"echo", label:"echo", desc:"Trung tính" },
  { id:"fable", label:"fable", desc:"Kể chuyện" },
  { id:"nova", label:"nova", desc:"Cảm xúc, cuốn" },
  { id:"onyx", label:"onyx", desc:"Trầm, nam tính" },
  { id:"sage", label:"sage", desc:"Điềm tĩnh" },
  { id:"shimmer", label:"shimmer", desc:"Nhẹ, nữ dịu" },
  { id:"verse", label:"verse", desc:"Tự nhiên, hiện đại" },
  { id:"marin", label:"marin", desc:"Chất lượng cao, mượt" },
  { id:"cedar", label:"cedar", desc:"Chất lượng cao, trầm ấm" }
];

const presets = [
  { key:"story", label:"Kể chuyện cảm xúc", voice:"nova", instructions:"kể chuyện cảm xúc, ấm áp, ngắt nghỉ tự nhiên, chậm vừa" },
  { key:"healing", label:"Nhẹ nhàng chữa lành", voice:"shimmer", instructions:"dịu dàng, nữ tính, mượt mà, cảm xúc nhẹ, rõ chữ" },
  { key:"youtube", label:"Lời dẫn YouTube", voice:"coral", instructions:"trẻ trung, rõ chữ, có năng lượng, tự nhiên" },
  { key:"narration", label:"Thuyết minh rõ chữ", voice:"ash", instructions:"rõ chữ, sạch, đều nhịp, trung tính" },
  { key:"deep", label:"Nam trầm", voice:"onyx", instructions:"nam trầm, ấm, chắc, chậm vừa, uy tín" },
  { key:"female", label:"Nữ dịu", voice:"marin", instructions:"nữ dịu dàng, mềm, sáng, cảm xúc vừa" }
];

const $ = (id) => document.getElementById(id);

let selectedVoice = "echo";
let generatedBlob = null;
let generatedUrl = "";
let previewAudio = null;

function setStatus(msg){
  $("status").textContent = msg;
}
function updateCharCount(){
  $("charCount").textContent = `${$("text").value.length} ký tự`;
}
function updateSpeedValue(){
  $("speedValue").textContent = Number($("speed").value).toFixed(2);
}
function saveLocal(){
  localStorage.setItem("tts_ultra_voice", selectedVoice);
  localStorage.setItem("tts_ultra_instructions", $("instructions").value);
  localStorage.setItem("tts_ultra_fileName", $("fileName").value);
  localStorage.setItem("tts_ultra_speed", $("speed").value);
  localStorage.setItem("tts_ultra_format", $("format").value);
  localStorage.setItem("tts_ultra_model", $("model").value);
  localStorage.setItem("tts_ultra_remember", $("rememberKey").checked ? "1" : "0");
  if($("rememberKey").checked){
    localStorage.setItem("tts_ultra_apiKey", $("apiKey").value);
  }else{
    localStorage.removeItem("tts_ultra_apiKey");
  }
}
function loadLocal(){
  const v = localStorage.getItem("tts_ultra_voice");
  if(v) selectedVoice = v;
  const ins = localStorage.getItem("tts_ultra_instructions");
  if(ins) $("instructions").value = ins;
  const fn = localStorage.getItem("tts_ultra_fileName");
  if(fn) $("fileName").value = fn;
  const sp = localStorage.getItem("tts_ultra_speed");
  if(sp) $("speed").value = sp;
  const fm = localStorage.getItem("tts_ultra_format");
  if(fm) $("format").value = fm;
  const md = localStorage.getItem("tts_ultra_model");
  if(md) $("model").value = md;
  const rk = localStorage.getItem("tts_ultra_remember");
  if(rk === "0") $("rememberKey").checked = false;
  const key = localStorage.getItem("tts_ultra_apiKey");
  if(key) $("apiKey").value = key;
}
function renderPresets(){
  $("presetWrap").innerHTML = "";
  presets.forEach(p => {
    const btn = document.createElement("button");
    btn.className = "pill" + (selectedVoice === p.voice && $("instructions").value === p.instructions ? " active" : "");
    btn.textContent = p.label;
    btn.onclick = () => {
      selectedVoice = p.voice;
      $("instructions").value = p.instructions;
      renderVoices();
      renderPresets();
      saveLocal();
      setStatus(`Đã chọn preset: ${p.label}`);
    };
    $("presetWrap").appendChild(btn);
  });
}
function renderVoices(){
  $("voiceGrid").innerHTML = "";
  voices.forEach(v => {
    const div = document.createElement("div");
    div.className = "voiceCard" + (selectedVoice === v.id ? " active" : "");
    div.innerHTML = `
      <div class="voiceName">${v.label}</div>
      <div class="voiceMeta">${v.desc}</div>
      <div class="inlineBtns">
        <button class="blue" type="button">Nghe thử</button>
        <button class="ghost" type="button">Chọn</button>
      </div>
    `;
    const [previewBtn, selectBtn] = div.querySelectorAll("button");
    previewBtn.onclick = () => previewVoice(v.id);
    selectBtn.onclick = () => {
      selectedVoice = v.id;
      renderVoices();
      renderPresets();
      saveLocal();
      setStatus(`Đã chọn voice: ${v.id}`);
    };
    $("voiceGrid").appendChild(div);
  });
}
async function callSpeechAPI(text, voice){
  const key = $("apiKey").value.trim();
  if(!key){
    alert("Bạn chưa nhập OpenAI API key");
    throw new Error("Thiếu API key");
  }
  const payload = {
    model: $("model").value,
    voice: voice,
    input: text,
    speed: Number($("speed").value),
    format: $("format").value,
    response_format: $("format").value,
    instructions: $("instructions").value.trim()
  };
  const res = await fetch("https://api.openai.com/v1/audio/speech", {
    method: "POST",
    headers: {
      "Authorization": "Bearer " + key,
      "Content-Type": "application/json"
    },
    body: JSON.stringify(payload)
  });
  if(!res.ok){
    const errText = await res.text().catch(() => "");
    throw new Error(`HTTP ${res.status}\n${errText}`);
  }
  return await res.blob();
}
async function previewVoice(voice){
  try{
    setStatus(`Đang nghe thử voice: ${voice}...`);
    if(previewAudio){
      previewAudio.pause();
      previewAudio = null;
    }
    const blob = await callSpeechAPI(`Xin chào, đây là giọng ${voice}`, voice);
    const url = URL.createObjectURL(blob);
    previewAudio = new Audio(url);
    previewAudio.play();
    setStatus(`Đang phát thử voice: ${voice}`);
  }catch(err){
    setStatus("Lỗi nghe thử:\n" + err.message);
  }
}
async function generateAudio(){
  try{
    const text = $("text").value.trim();
    if(!text){
      alert("Bạn chưa nhập nội dung");
      return;
    }
    saveLocal();
    setStatus("Đang tạo audio...");
    const blob = await callSpeechAPI(text, selectedVoice);
    generatedBlob = blob;
    if(generatedUrl) URL.revokeObjectURL(generatedUrl);
    generatedUrl = URL.createObjectURL(blob);
    $("audioPlayer").src = generatedUrl;
    setStatus(`Tạo audio thành công với voice: ${selectedVoice}`);
  }catch(err){
    setStatus("Lỗi tạo audio:\n" + err.message);
  }
}
function playAudio(){
  if(!$("audioPlayer").src){
    alert("Chưa có audio để phát");
    return;
  }
  $("audioPlayer").play();
}
function downloadAudio(){
  if(!generatedBlob){
    alert("Chưa có audio để tải");
    return;
  }
  const ext = $("format").value || "mp3";
  const name = ($("fileName").value || "doanlifestyle_tts_ultra").trim();
  const a = document.createElement("a");
  a.href = generatedUrl;
  a.download = `${name}.${ext}`;
  document.body.appendChild(a);
  a.click();
  a.remove();
}
function resetAll(){
  $("text").value = `Xin chào bạn...
Hôm nay...
mình đã gom cho bạn bản đầy đủ hơn...

Bạn chỉ cần dán nội dung vào đây...
chọn giọng đọc mình thích...
rồi bấm tạo audio...

Sau đó...
bạn có thể tải file về iPhone.`;
  $("instructions").value = "dịu dàng, nữ tính, mượt mà, cảm xúc nhẹ, rõ chữ";
  $("fileName").value = "doanlifestyle_tts_ultra";
  $("format").value = "mp3";
  $("model").value = "gpt-4o-mini-tts";
  $("speed").value = "1.50";
  selectedVoice = "echo";
  updateSpeedValue();
  updateCharCount();
  renderVoices();
  renderPresets();
  saveLocal();
  setStatus("Đã đặt lại.");
}
function setSamples(type){
  if(type === "story"){
    $("text").value = `Xin chào các bạn...
Hôm nay...
mình muốn kể cho bạn nghe...
một câu chuyện ngắn...
nhưng đầy cảm xúc.`;
    $("instructions").value = "kể chuyện cảm xúc, ấm áp, ngắt nghỉ tự nhiên, chậm vừa";
    selectedVoice = "nova";
  } else if(type === "healing"){
    $("text").value = `Nếu hôm nay lòng bạn đang mỏi mệt...
hãy dừng lại một chút...
hít vào thật sâu...
thở ra thật chậm...
bình an có thể bắt đầu lại từ đây.`;
    $("instructions").value = "dịu dàng, nữ tính, chữa lành, nhẹ, rõ chữ";
    selectedVoice = "shimmer";
  } else if(type === "youtube"){
    $("text").value = `Xin chào các bạn...
chào mừng bạn đến với kênh của mình...
trong video hôm nay...
mình sẽ chia sẻ với bạn...
một nội dung ngắn nhưng rất đáng để nghe đến cuối.`;
    $("instructions").value = "trẻ trung, rõ chữ, có năng lượng, tự nhiên";
    selectedVoice = "coral";
  }
  updateCharCount();
  renderVoices();
  renderPresets();
  saveLocal();
}

$("text").addEventListener("input", updateCharCount);
$("speed").addEventListener("input", () => { updateSpeedValue(); saveLocal(); });
$("instructions").addEventListener("input", () => { renderPresets(); saveLocal(); });
$("fileName").addEventListener("input", saveLocal);
$("format").addEventListener("change", saveLocal);
$("model").addEventListener("change", saveLocal);
$("apiKey").addEventListener("input", saveLocal);
$("rememberKey").addEventListener("change", saveLocal);

$("sampleStoryBtn").onclick = () => setSamples("story");
$("sampleHealingBtn").onclick = () => setSamples("healing");
$("sampleYoutubeBtn").onclick = () => setSamples("youtube");
$("clearBtn").onclick = () => { $("text").value = ""; updateCharCount(); };
$("generateBtn").onclick = generateAudio;
$("previewBtn").onclick = playAudio;
$("downloadBtn").onclick = downloadAudio;
$("resetBtn").onclick = resetAll;

loadLocal();
updateCharCount();
updateSpeedValue();
renderVoices();
renderPresets();
</script>
</body>
</html>
